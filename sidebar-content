<!-- ============================================
     SIDEBAR CONTENT - Single source of truth
     ============================================ -->

<!-- Sidebar Overlay (for mobile) -->
<div id="sidebar-overlay" class="fixed inset-0 bg-black/50 z-40 hidden" onclick="closeMobileMenu()"></div>

<!-- Mobile Sidebar -->
<aside id="mobile-sidebar" class="sidebar fixed top-0 left-0 h-full w-64 z-50 overflow-y-auto">
    <div class="p-4 border-b flex justify-between items-center">
        <div class="flex items-center space-x-2">
            <i class="fas fa-store text-2xl text-purple-500"></i>
            <span class="text-xl font-bold">Marketplace Pro</span>
        </div>
        <button onclick="closeMobileMenu()" class="text-2xl">&times;</button>
    </div>
    <div class="p-4">
        <div class="text-xs opacity-60 mb-4" id="mobile-panel-label">Admin Panel</div>
        <nav id="mobile-nav"></nav>
    </div>
    <div class="absolute bottom-0 w-full p-4 border-t">
        <button onclick="logout()" class="w-full text-left nav-item">
            <i class="fas fa-sign-out-alt w-5"></i>
            <span>Logout</span>
        </button>
    </div>
</aside>

<!-- Desktop Sidebar -->
<aside class="desktop-sidebar sidebar w-64 overflow-y-auto hidden md:block">
    <div class="p-4 border-b">
        <div class="flex items-center space-x-2 sidebar-logo">
            <i class="fas fa-store text-2xl text-purple-500"></i>
            <span class="text-xl font-bold">Marketplace Pro</span>
        </div>
        <p class="text-xs opacity-60 mt-2" id="desktop-panel-label">Admin Panel</p>
    </div>
    <nav id="desktop-nav"></nav>
    <div class="absolute bottom-0 w-full p-4 border-t">
        <button onclick="logout()" class="w-full text-left nav-item">
            <i class="fas fa-sign-out-alt w-5"></i>
            <span>Logout</span>
        </button>
    </div>
</aside>
